# ===================================================
# MyCoinBot 환경변수 설정
# 이 파일을 .env.local로 복사한 뒤 실제 값을 입력하세요.
#   cp .env.example .env.local
# ===================================================

# ─── Supabase ───────────────────────────────────────
# Supabase 프로젝트 > Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DB 스키마 (기본값: public)
NEXT_PUBLIC_DB_SCHEMA=public

# ─── 보안 ───────────────────────────────────────────
# JWT 세션 서명용 시크릿 (최소 32자 랜덤 문자열)
#   생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=your-session-secret-min-32-chars

# API 키 암호화용 키 (64자 hex 문자열 = 256bit)
#   생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-string-generated-by-openssl-rand-hex-32

# HTTPS 전용 쿠키 (프로덕션에서는 자동으로 true 적용됨)
# 로컬 개발 시에는 생략하거나 false로 설정
SECURE_COOKIE=false

# ─── 관리자 ─────────────────────────────────────────
# 관리자 권한을 가질 로그인 ID (회원가입 시 사용한 아이디)
ADMIN_USER_ID=admin

# ─── Cron 스케줄러 ──────────────────────────────────
# cron-job.org 또는 로컬 cron에서 /api/cron 호출 시 사용하는 Bearer 토큰
#   생성: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=your-cron-secret-token

# ─── 카카오 로그인 ───────────────────────────────────
# 카카오 개발자센터 > 앱 > 플랫폼 키에서 확인
NEXT_PUBLIC_KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_REST_API_KEY=your-kakao-rest-api-key

# ─── Gmail 이메일 인증 ──────────────────────────────
# Google 계정 > 보안 > 2단계 인증 > 앱 비밀번호에서 생성
GMAIL_USER=sinergy119@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# ─── Telegram 알림 (선택) ───────────────────────────
# @BotFather에서 봇 생성 후 발급받은 토큰
# 미설정 시 알림 기능이 비활성화됩니다
TELEGRAM_BOT_TOKEN=

# ─── Firebase (FCM 앱 푸시) ─────────────────────────
# Firebase Console > 프로젝트 설정 > 일반 탭의 "SDK 설정 및 구성" 참조
# 클라이언트 공개 값 (번들에 포함됨)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBzCtczwiDJwzGTw8v0lRRuoxI5Enlp7Zg
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=mycoinbot-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=mycoinbot-app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=mycoinbot-app.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=201995976563
NEXT_PUBLIC_FIREBASE_APP_ID=1:201995976563:web:2af1925a084325bb5d4f06

# 웹 푸시 인증서 공개키 (Firebase Console > 프로젝트 설정 > Cloud Messaging > 웹 푸시 인증서)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=BDfMI4syWDDKXsFRa0vJRPfePKpcTeG1MW_wFBL6AyVh070qjuByWYyfLJY-AdJPR-d0RbrYQsW8EzUi3OBpJRY

# 서버 Admin SDK (서비스 계정 JSON 파일 경로)
# - 로컬: 이 저장소의 secrets/firebase-adminsdk.json (git 제외)
# - EC2: /home/ec2-user/coinbot/secrets/firebase-adminsdk.json
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-adminsdk.json

# ─── 빌드 정보 (선택) ───────────────────────────────
# Vercel 배포 시 자동 설정. 수동 설정 불필요
NEXT_PUBLIC_BUILD_TIME=
